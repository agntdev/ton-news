{
  "name": "ton-news",
  "version": "0.1.0",
  "private": true,
  "description": "SEO-focused news platform for the TON blockchain ecosystem.",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "ton-storage:export": "node scripts/ton-storage.mjs export",
    "ton-storage:register": "node scripts/ton-storage.mjs register",
    "content:backup": "node scripts/content-maintenance.mjs backup",
    "content:publish-due": "node scripts/content-maintenance.mjs publish-due",
    "content:restore": "node scripts/content-maintenance.mjs restore",
    "seed": "node scripts/seed-users.mjs"
  },
  "dependencies": {
    "next": "14.2.13",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.13",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.13",
    "typescript": "5.5.4"
  }
}
